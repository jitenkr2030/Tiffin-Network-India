generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model TiffinOrder {
  id                  String   @id @default(cuid())
  customerName        String
  mobileNumber        String
  address             String
  area                String
  tiffinType          String
  quantity            Int
  deliveryTime        String
  startDate           DateTime
  subscriptionType    String
  specialInstructions String?
  orderStatus         String   @default("New Order")
  totalPrice          Float
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model TiffinMenu {
  id          String @id @default(cuid())
  name        String
  description String
  price       Float
  type        String
  isAvailable Boolean @default(true)
}